{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PORT": 8080,
  "Jwt": {
    "Key": "",
    "Issuer": "ReportTree",
    "ExpiryHours": 8
  },
  "Database": {
    "Provider": "LiteDb",
    "ConnectionString": "",
    "BrandingAssetsPath": "data/branding-assets"
  },
  "LiteDb": {
    "ConnectionString": "Filename=reporttree.db;Connection=shared"
  },
  "PowerBI": {
    "TenantId": "",
    "ClientId": "",
    "ClientSecret": "",
    "AuthType": "ClientSecret",
    "CertificateThumbprint": "",
    "CertificatePath": "",
    "AuthorityUrl": "https://login.microsoftonline.com/{0}/",
    "ResourceUrl": "https://analysis.windows.net/powerbi/api",
    "ApiUrl": "https://api.powerbi.com"
  },
  "Refresh": {
    "MaxConcurrentPerDataset": 1,
    "ManualCooldownSeconds": 60,
    "DefaultRetryCount": 2,
    "DefaultRetryBackoffSeconds": 120,
    "PollIntervalSeconds": 60
  },
  "Email": {
    "Enabled": false,
    "Host": "",
    "Port": 587,
    "UseSsl": true,
    "Username": "",
    "Password": "",
    "FromAddress": "",
    "FromName": "PBIHoster"
  },
  "Security": {
    "PasswordPolicy": {
      "MinLength": 8,
      "MaxLength": 128,
      "RequireUppercase": true,
      "RequireLowercase": true,
      "RequireDigit": true,
      "RequireSpecialChar": true,
      "MaxFailedAccessAttempts": 5,
      "LockoutMinutes": 15
    },
    "RateLimitPolicy": {
      "Enabled": true,
      "GeneralLimit": 100,
      "GeneralPeriod": "1m",
      "AuthLimit": 5,
      "AuthPeriod": "1m"
    },
    "CorsPolicy": {
      "AllowedOrigins": [],
      "AllowCredentials": true
    },
    "ContentSecurityPolicy": {
      "DefaultSources": [ "'self'" ],
      "FrameSources": [ "'self'", "https://app.powerbi.com", "https://*.powerbi.com" ],
      "ScriptSources": [ "'self'", "https://js.powerbi.com" ],
      "StyleSources": [ "'self'", "'unsafe-inline'", "https://fonts.googleapis.com" ],
      "ImgSources": [ "'self'", "data:", "https://*.powerbi.com" ],
      "ConnectSources": [ "'self'", "https://api.powerbi.com", "https://*.analysis.windows.net" ],
      "FontSources": [ "'self'", "data:" ],
      "FrameAncestors": [ "'self'" ]
    },
    "ExternalAuth": {
      "Enabled": false,
      "Providers": [
        {
          "Id": "entra",
          "DisplayName": "Microsoft Entra ID",
          "Enabled": false,
          "Authority": "https://login.microsoftonline.com/<tenant-id>/v2.0",
          "ClientId": "",
          "ClientSecret": "",
          "RequireHttpsMetadata": true,
          "CallbackPath": "/signin-oidc-entra",
          "Scopes": [ "openid", "profile", "email" ],
          "DefaultRole": "Viewer",
          "GroupSyncEnabled": false,
          "GroupClaimType": "groups",
          "RemoveUnmappedGroupMemberships": false,
          "GroupMappings": [
            {
              "ExternalGroup": "entra-group-object-id",
              "InternalGroup": "Sales"
            }
          ],
          "RoleSyncEnabled": false,
          "RoleClaimType": "roles",
          "RoleMappings": [
            {
              "ExternalRole": "PBIHoster-Editors",
              "InternalRole": "Editor"
            }
          ]
        }
      ]
    }
  }
}
